NODE_ENV=development
PORT=3000
JWT_SECRET=replace-with-a-long-random-secret
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=pos_glasses
PUBLIC_APP_URL=http://localhost:3000
CORS_ORIGINS=http://localhost:3000
# Set to the number of trusted reverse proxies in production (often 1).
TRUST_PROXY=false
# Leave unset to use pos_session locally and __Host-pos_session in production.
# SESSION_COOKIE_NAME=
SESSION_TTL_HOURS=24

# First start only. Required when production database has no users.
# Remove these secrets after the first administrator has been created.
BOOTSTRAP_ADMIN_USERNAME=
BOOTSTRAP_ADMIN_PASSWORD=

# Payment verification. fake is allowed only outside production.
PAYMENT_PROVIDER=fake
# auto accepts either the configured API Key or HMAC-SHA256. In production,
# prefer hmac and configure the same secret on the SePay webhook dashboard.
PAYMENT_WEBHOOK_AUTH=auto
PAYMENT_WEBHOOK_SECRET=
PAYMENT_WEBHOOK_API_KEY=
PAYMENT_WEBHOOK_MAX_SKEW_SECONDS=300
PAYMENT_ACCOUNT_NUMBER=
PAYMENT_BANK_CODE=
PAYMENT_INTENT_TTL_MINUTES=30
PAYMENT_LATE_MATCH_WINDOW_MINUTES=60
PAYMENT_TEST_MODE=false
PAYMENT_TEST_AMOUNT=2900

# Product image storage. CLOUDINARY_URL can replace the three explicit keys.
CLOUDINARY_ENABLED=false
CLOUDINARY_URL=
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_PRODUCT_FOLDER=pos-glasses/products

# Gemini AI
AI_ENABLED=false
GEMINI_API_KEY=
GEMINI_DEFAULT_MODEL=gemini-3.1-flash-lite
GEMINI_ANALYSIS_MODEL=gemini-3.5-flash
AI_DAILY_BUDGET_USD=5
